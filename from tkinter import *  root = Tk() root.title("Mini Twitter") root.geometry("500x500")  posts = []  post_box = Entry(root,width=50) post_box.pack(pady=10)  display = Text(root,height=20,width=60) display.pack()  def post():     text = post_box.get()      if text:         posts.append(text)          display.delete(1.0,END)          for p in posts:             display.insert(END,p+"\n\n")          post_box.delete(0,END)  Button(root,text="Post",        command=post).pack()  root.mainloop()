from tkinter import *

root = Tk()
root.title("Mini Twitter")
root.geometry("500x500")

posts = []

post_box = Entry(root,width=50)
post_box.pack(pady=10)

display = Text(root,height=20,width=60)
display.pack()

def post():
    text = post_box.get()

    if text:
        posts.append(text)

        display.delete(1.0,END)

        for p in posts:
            display.insert(END,p+"\n\n")

        post_box.delete(0,END)

Button(root,text="Post",
       command=post).pack()

root.mainloop()
